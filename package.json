{
  "name": "blog.thinceller.net",
  "version": "1.0.0",
  "author": "thinceller <thinceller@gmail.com>",
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "6.7.2",
    "@fortawesome/free-brands-svg-icons": "6.7.2",
    "@fortawesome/free-solid-svg-icons": "6.7.2",
    "@fortawesome/react-fontawesome": "0.2.2",
    "@mdx-js/mdx": "3.1.0",
    "@mdx-js/react": "3.1.0",
    "@shikijs/langs": "3.4.2",
    "@shikijs/rehype": "3.4.2",
    "@shikijs/themes": "3.4.2",
    "dayjs": "1.11.13",
    "feed": "5.1.0",
    "gray-matter": "4.0.3",
    "next": "15.3.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-twitter-widgets": "1.11.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-code-titles": "1.2.0",
    "rehype-slug": "6.0.0",
    "shiki": "3.4.2",
    "valibot": "1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@next/bundle-analyzer": "15.3.5",
    "@opennextjs/aws": "3.6.6",
    "@opennextjs/cloudflare": "1.2.1",
    "@textlint/textlint-plugin-markdown": "14.7.2",
    "@types/gtag.js": "0.0.20",
    "@types/markdown-it": "14.1.2",
    "@types/mdx": "2.0.13",
    "@types/node": "22.15.32",
    "@types/react": "19.1.8",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "textlint": "14.7.2",
    "textlint-rule-preset-ja-spacing": "2.4.3",
    "textlint-rule-preset-ja-technical-writing": "12.0.2",
    "textlint-rule-spellcheck-tech-word": "5.0.0",
    "typescript": "5.8.3",
    "wrangler": "4.17.0"
  },
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
  "scripts": {
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "dev": "next dev --turbopack",
    "start": "next start",
    "lint": "biome check",
    "lint:post": "textlint _posts/**/*.mdx",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview -- --minify",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --minify",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload -- --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "nextBundleAnalysis": {
    "budget": 358400,
    "budgetPercentIncreaseRed": 20,
    "showDetails": true
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "workerd"
    ]
  }
}
